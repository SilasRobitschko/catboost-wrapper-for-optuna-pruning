# .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/

# Environments
.env
.venv
env/
venv/
ENV/

# IDEs and Editors
.vscode/
.idea/
*.swp

# CatBoost specific
catboost_info/

# Machine Learning Models & Artifacts
*.cbm      
*.onnx     
*.pmml    
*.coreml   

# Optuna specific (if you use SQLite locally)
*.db
*.sqlite3

# OS generated files
.DS_Store
Thumbs.db